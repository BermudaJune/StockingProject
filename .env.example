WUYIN_API_KEY=your_wuyin_api_key_here
WUYIN_IMAGE_API_URL=https://api.wuyinkeji.com/api/async/image_gpt
WUYIN_IMAGE_DETAIL_API_URL=https://api.wuyinkeji.com/api/async/detail

# provider: openai | banana
IMAGE_PROVIDER=openai

# oyy (OpenAI-compatible relay)
OYY_BASE_URL=https://www.oyy-ai.com
OYY_API_KEY=your_oyy_api_key_here
OYY_MODEL=gpt-image-2
OYY_IMAGE_API_PATH=/v1/images/edits

# gemini
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_PATH=/v1beta/models/gemini-3-pro-image-preview:generateContent
GEMINI_API_KEY=your_gemini_api_key_here

# openai chat completions
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_API_PATH=/v1/chat/completions
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_API_KEY=your_openai_api_key_here
